datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  orders    Order[]
  reviews   Review[]
  favorites Favorite[]
}

enum Role {
  USER
  ADMIN
}

model League {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  logo  String?

  clubs Club[]
}

model Club {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logo     String?
  leagueId String

  league   League  @relation(fields: [leagueId], references: [id])
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Float
  images      String[]
  description String
  stock       Int      @default(0)
  isNew       Boolean  @default(false)
  clubId      String

  club       Club       @relation(fields: [clubId], references: [id])
  reviews    Review[]
  orderItems OrderItem[]
  favorites  Favorite[]
  createdAt  DateTime   @default(now())
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Float
  status    OrderStatus @default(PENDING)
  stripeId  String?
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  size      String
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Favorite {
  id        String @id @default(cuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}